# Django configuration
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
USE_SQLITE=False

# Database configuration
DB_NAME=manxiai
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=10
# Disable libpq GSS negotiation by default on Windows/local networks; it can add 15-20s per first connection.
DB_GSSENCMODE=disable
# Use require/verify-full only when the PostgreSQL server is configured for SSL.
DB_SSLMODE=disable
DB_APPLICATION_NAME=manxiai-django

# Redis configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# DeepSeek configuration
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Supported values: deepseek, openai, debug
# debug is for local smoke tests only and does not call an external LLM.
DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_LLM_MODEL=deepseek-chat

# OpenAI configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding configuration
# Supported values:
# - openai: use OPENAI_BASE_URL + /embeddings and OPENAI_API_KEY
# - http_openai_compatible: use EMBEDDING_API_URL and EMBEDDING_API_KEY
# - hash_debug: local deterministic vectors for development smoke tests only
EMBEDDING_PROVIDER=http_openai_compatible
EMBEDDING_MODEL=bge-large-zh-v1.5
EMBEDDING_DIMENSIONS=1024
EMBEDDING_API_URL=http://127.0.0.1:8884/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_REQUEST_TIMEOUT=60
EMBEDDING_BATCH_SIZE=16
RUN_BACKGROUND_TASKS_SYNC=False

# Vector search configuration
SIMILARITY_THRESHOLD=0.7
TOP_K=5

# Logging configuration
DJANGO_LOG_LEVEL=INFO
MANXIAI_LOG_LEVEL=INFO
